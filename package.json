{
    "name": "neutda-ai",
    "version": "1.0.0",
    "description": "Express API that proxies chat requests to a local llama.cpp server running the Qwen vision model.",
    "type": "module",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "node --watch src/server.js",
        "up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-all.ps1",
        "down": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
        "llama": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-llama-server.ps1",
        "cluster": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-llama-cluster.ps1"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "adm-zip": "^0.5.17",
        "cfb": "^1.2.2",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "mammoth": "^1.12.0",
        "multer": "^2.2.0",
        "pdf-parse": "^2.4.5"
    }
}
