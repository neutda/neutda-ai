# Express 서버 포트
PORT=3000

# LLM 백엔드 목록 (tier@url). tier=large/small. 라우터가 티어를 고르고 그 안에서 로드밸런싱.
# 예: LLAMA_BACKENDS=large@http://127.0.0.1:8080,small@http://127.0.0.1:8081,small@http://192.168.0.20:8080
LLAMA_BACKENDS=large@http://127.0.0.1:8080,small@http://127.0.0.1:8081

# (구버전 호환) 태그 없는 평면 목록. LLAMA_BACKENDS 가 있으면 무시(전부 large 취급).
LLAMA_SERVERS=http://127.0.0.1:8080
LLAMA_SERVER_URL=http://127.0.0.1:8080

# 라우팅 정책
API_KEY=tw-demo-key-2026  # 외부 GET API(/api/ask) 인증 키(고정값)
DEFAULT_TIER=small        # 휴리스틱상 "간단"으로 판정될 때 쓸 티어 (small/medium/large)
SMALL_MAX_CHARS=200       # 이 글자수 이하 = small, 그 사이 = medium
LARGE_MIN_CHARS=600       # 이 글자수 초과(또는 코드/복잡키워드) = large
GPU_MIN_DIFFICULTY=50     # 난이도 점수(0~100)가 이 값 이상이면 같은 티어 내 GPU 선호(이하면 CPU)
ESCALATE_TIER=true        # 선택된 티어가 전부 다운이면 다른 티어로 폴백

# llama-server에 전달할 모델 이름(라벨). llama-server는 보통 이 값을 무시하지만 응답에 표기됩니다.
MODEL_NAME=qwen

# 기본 생성 파라미터 (요청에 값이 없을 때 사용)
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048

# Qwen3.6 추론(thinking) 모드 기본값. false 면 추론 과정 없이 바로 답변.
# 요청 body 의 "THINKING": true/false 로 개별 요청마다 덮어쓸 수 있음.
ENABLE_THINKING=false

# 모델 추론 요청 타임아웃(ms)
REQUEST_TIMEOUT_MS=120000

# 백엔드 헬스체크 주기(ms)
HEALTH_INTERVAL_MS=5000

# 요청 실패 시 다른 백엔드로 재시도(failover) 횟수
MAX_RETRIES=2
